# Supabase project settings — see README.md "Setup" for how to create these.
# Project Settings > API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — never expose to the client, never commit a real value.
# Used by scripts/seed.ts to bypass RLS when writing to the `cards` table.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth — only needed to run Google sign-in against LOCAL Supabase
# (`supabase start`, which reads these via config.toml's env() refs). Create an
# OAuth client in Google Cloud Console (see README "Google sign-in"). For the
# hosted project, set these in Authentication > Providers > Google instead.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-oauth-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-oauth-client-secret
